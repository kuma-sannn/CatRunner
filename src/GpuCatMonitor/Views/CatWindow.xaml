<Window x:Class="GpuCatMonitor.Views.CatWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:tb="http://www.hardcodet.net/taskbar"
        Title="GPU Cat Monitor"
        Width="140" Height="140"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Visibility="Collapsed"
        MouseLeftButtonDown="OnMouseLeftButtonDown">
    
    <Grid>
        <!-- System Tray Icon -->
        <tb:TaskbarIcon x:Name="TrayIcon"
                        ToolTipText="GPU Cat Monitor - Loading..."
                        TrayMouseDoubleClick="OnTrayDoubleClick"
                        Visibility="Visible">
            <tb:TaskbarIcon.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Animation Mode">
                        <MenuItem x:Name="ModeAdaptiveMenuItem" Header="Adaptive (Auto)" IsCheckable="True" Click="OnModeSelected"/>
                        <MenuItem x:Name="ModeGpuMenuItem" Header="GPU Only" IsCheckable="True" Click="OnModeSelected"/>
                        <MenuItem x:Name="ModeCpuMenuItem" Header="CPU Only" IsCheckable="True" Click="OnModeSelected"/>
                    </MenuItem>
                    <Separator/>
                    <MenuItem x:Name="ToggleWindowMenuItem" Header="Show Floating Cat" Click="OnToggleFloatingWindow"/>
                    <MenuItem x:Name="RunOnStartupMenuItem" Header="Start with Windows" IsCheckable="True" Click="OnToggleStartup"/>
                    <Separator/>
                    <MenuItem Header="Exit" Click="OnExit"/>
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>
            
            <!-- Simple Tooltip with stats -->
            <tb:TaskbarIcon.TrayToolTip>
                <Border Background="#FF1E1E1E" 
                        CornerRadius="8" 
                        Padding="12"
                        BorderBrush="#FF333333"
                        BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="GPU Cat Monitor" 
                                   Foreground="White" 
                                   FontSize="14" 
                                   FontWeight="Bold"
                                   Margin="0,0,0,8"/>
                        <TextBlock x:Name="GpuNameText"
                                   Text="GPU: Loading..." 
                                   Foreground="#AAAAAA" 
                                   FontSize="11"
                                   Margin="0,0,0,4"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="GPU: " Foreground="#AAAAAA" FontSize="12"/>
                            <TextBlock x:Name="GpuUsageText" 
                                       Grid.Column="1"
                                       Text="0%" 
                                       Foreground="#00FF00" 
                                       FontSize="12" 
                                       FontWeight="Bold"/>
                        </Grid>
                        <Grid Margin="0,2,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="CPU: " Foreground="#AAAAAA" FontSize="12"/>
                            <TextBlock x:Name="CpuUsageText" 
                                       Grid.Column="1"
                                       Text="0%" 
                                       Foreground="#00BFFF" 
                                       FontSize="12" 
                                       FontWeight="Bold"/>
                        </Grid>
                        <TextBlock x:Name="TrayModeText"
                                   Text="Anim: GPU" 
                                   Foreground="#FFAA00" 
                                   FontSize="10"
                                   Margin="0,4,0,0"
                                   FontWeight="Bold"/>
                        <TextBlock Text="(Double-click for floating cat)" 
                                   Foreground="#666666" 
                                   FontSize="9"
                                   Margin="0,4,0,0"
                                   FontStyle="Italic"/>
                    </StackPanel>
                </Border>
            </tb:TaskbarIcon.TrayToolTip>
        </tb:TaskbarIcon>
        
        <!-- Floating Cat Window Content -->
        <Grid x:Name="FloatingWindowContent" Background="Transparent">
            <Border x:Name="CatContainer"
                    Width="100" Height="80"
                    Background="Transparent">
                <Image x:Name="CatImage"
                       Stretch="Uniform"
                       Width="100"
                       Height="80" />
            </Border>
                
            <!-- Stats Panel (shown on hover over floating window) -->
            <Popup x:Name="StatsPopup"
                   Placement="Top"
                   PlacementTarget="{Binding ElementName=CatContainer}"
                   HorizontalOffset="0"
                   VerticalOffset="-10"
                   IsOpen="False"
                   StaysOpen="True">
                <Border Background="#CC000000"
                        CornerRadius="8"
                        Padding="10,8"
                        MinWidth="100">
                    <StackPanel>
                        <TextBlock x:Name="AnimationModeText"
                                   Text="Mode: GPU" 
                                   Foreground="#FFAA00"
                                   FontSize="9"
                                   FontWeight="Bold"
                                   Margin="0,0,0,4"/>
                        <TextBlock x:Name="FloatingGpuNameText"
                                   Text="GPU" 
                                   Foreground="White"
                                   FontSize="10"
                                   FontWeight="Bold"/>
                        <TextBlock x:Name="FloatingGpuUsageText"
                                   Text="0%" 
                                   Foreground="#00FF00"
                                   FontSize="14"
                                   FontWeight="Bold"/>
                        <TextBlock x:Name="FloatingCpuUsageText"
                                   Text="CPU: 0%" 
                                   Foreground="#00BFFF"
                                   FontSize="10"/>
                    </StackPanel>
                </Border>
            </Popup>
        </Grid>
    </Grid>
</Window>
