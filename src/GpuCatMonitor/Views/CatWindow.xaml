<Window x:Class="GpuCatMonitor.Views.CatWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:tb="http://www.hardcodet.net/taskbar"
        Title="GPU Cat Monitor"
        Width="0" Height="0"
        WindowStyle="None"
        ShowInTaskbar="False"
        Visibility="Collapsed">
    
    <Grid>
        <!-- System Tray Icon - This is what shows in taskbar -->
        <tb:TaskbarIcon x:Name="TrayIcon"
                        IconSource="cat.ico"
                        ToolTipText="GPU Cat Monitor - Loading..."
                        TrayMouseDoubleClick="OnTrayDoubleClick"
                        Visibility="Visible">
            <tb:TaskbarIcon.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Show Cat Animation" Click="OnShowAnimation"/>
                    <MenuItem Header="Settings..." Click="OnSettings"/>
                    <Separator/>
                    <MenuItem Header="Exit" Click="OnExit"/>
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>
            
            <!-- Custom Tooltip with animated cat and stats -->
            <tb:TaskbarIcon.TrayToolTip>
                <Border Background="#FF1E1E1E" 
                        CornerRadius="8" 
                        Padding="12"
                        BorderBrush="#FF333333"
                        BorderThickness="1">
                    <StackPanel>
                        <!-- Title -->
                        <TextBlock Text="GPU Cat Monitor" 
                                   Foreground="White" 
                                   FontSize="14" 
                                   FontWeight="Bold"
                                   Margin="0,0,0,8"/>
                        
                        <!-- Animated Cat Image -->
                        <Border Background="#FF2D2D2D" 
                                CornerRadius="6" 
                                Padding="8"
                                Margin="0,0,0,8">
                            <Image x:Name="TooltipCatImage"
                                   Width="80" 
                                   Height="60"
                                   Stretch="Uniform"/>
                        </Border>
                        
                        <!-- GPU Stats -->
                        <StackPanel>
                            <TextBlock x:Name="GpuNameText"
                                       Text="GPU: Loading..." 
                                       Foreground="#AAAAAA" 
                                       FontSize="11"
                                       Margin="0,0,0,4"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="GPU: " Foreground="#AAAAAA" FontSize="12"/>
                                <TextBlock x:Name="GpuUsageText" 
                                           Grid.Column="1"
                                           Text="0%" 
                                           Foreground="#00FF00" 
                                           FontSize="12" 
                                           FontWeight="Bold"/>
                            </Grid>
                            <Grid Margin="0,2,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="CPU: " Foreground="#AAAAAA" FontSize="12"/>
                                <TextBlock x:Name="CpuUsageText" 
                                           Grid.Column="1"
                                           Text="0%" 
                                           Foreground="#00BFFF" 
                                           FontSize="12" 
                                           FontWeight="Bold"/>
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </tb:TaskbarIcon.TrayToolTip>
        </tb:TaskbarIcon>
        
        <!-- Hidden window content - used for animation rendering -->
        <Image x:Name="CatImage" Width="80" Height="60" Visibility="Collapsed"/>
    </Grid>
</Window>
